{
    "version": 1,
    "servers": [
        {
            "name": "playwright",
            "transport": "stdio",
            "command": "npx",
            "args": ["@playwright/mcp", "--headless"],
            "post_install_notes": null
        },
        {
            "name": "figma",
            "transport": "http",
            "url": "https://mcp.figma.com/mcp",
            "post_install_notes": "OAuth. After restarting Claude Code, run /mcp, select figma, and complete browser authentication."
        }
    ]
}
