{
  "feature": "cdd_spec_map",
  "harness_type": "web_test",
  "scenarios": [
    {
      "name": "spec_map_view_present",
      "setup_commands": [
        "tools/cdd/start.sh -p 9086 > /dev/null 2>&1; sleep 2"
      ],
      "web_test_url": "http://localhost:9086",
      "assertions": [
        {
          "tier": 2,
          "pattern": "Spec Map",
          "context": "Spec Map view toggle button present in dashboard header"
        },
        {
          "tier": 2,
          "pattern": "Recenter Graph",
          "context": "Recenter Graph button present in spec map canvas"
        },
        {
          "tier": 1,
          "pattern": "(?i)(cytoscape|switchView|recenterGraph)",
          "context": "spec map graph JS infrastructure present in page"
        }
      ]
    }
  ]
}
