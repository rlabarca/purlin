{
  "feature": "purlin_worktree_identity",
  "description": "Regression scenarios for Purlin worktree identity: badge format, label file handling, and non-worktree safety.",
  "harness_type": "custom_script",
  "scenarios": [
    {
      "name": "badge-no-purlin-prefix",
      "script_path": "tests/purlin_worktree_identity/test_badge_format.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "no Purlin: prefix found",
          "context": "Identity script never produces 'Purlin:' prefixed output"
        },
        {
          "tier": 2,
          "pattern": "unified format verified",
          "context": "Identity functions produce <short_mode>(<context>) | <label> format"
        }
      ]
    },
    {
      "name": "worktree-label-file-handling",
      "script_path": "tests/purlin_worktree_identity/test_label_file.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "gitignore contains purlin_worktree_label",
          "context": ".purlin_worktree_label is listed in .gitignore"
        },
        {
          "tier": 2,
          "pattern": "identity script reads label file",
          "context": "identity.sh _purlin_detect_context reads .purlin_worktree_label"
        }
      ]
    },
    {
      "name": "no-label-in-non-worktree",
      "script_path": "tests/purlin_worktree_identity/test_no_label.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "no label file in project root",
          "context": ".purlin_worktree_label does not exist in non-worktree project root"
        }
      ]
    },
    {
      "name": "mode-shortening-exhaustive",
      "script_path": "tests/purlin_worktree_identity/test_mode_shortening.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "case-insensitive mode shortening works",
          "context": "Engineer/engineer/ENGINEER all produce Eng; PM/pm produce PM; QA/qa produce QA"
        },
        {
          "tier": 2,
          "pattern": "empty and none modes produce Purlin",
          "context": "Empty string and 'none' both resolve to Purlin as default"
        },
        {
          "tier": 2,
          "pattern": "custom mode passes through unchanged",
          "context": "Unknown mode names pass through without modification"
        }
      ]
    }
  ]
}
