{
  "feature": "purlin_resume",
  "description": "Regression scenarios for purlin:resume save, merge-recovery, and checkpoint restore. Validates behavioral contracts from the unified agent session entry point.",
  "harness_type": "agent_behavior",
  "scenarios": [
    {
      "name": "save-writes-checkpoint-confirmation",
      "prompt": "purlin:resume save",
      "role": "PURLIN",
      "mode": "engineer",
      "fixture_tag": "main/pl_start/builder-mid-feature",
      "assertions": [
        {
          "tier": 2,
          "pattern": "Checkpoint saved|checkpoint would contain|Session Checkpoint",
          "context": "Save produces checkpoint content or confirmation"
        },
        {
          "tier": 2,
          "pattern": "Mode:\\s*(engineer|pm|qa|none)|Engineer|engineer",
          "context": "Output includes the current mode"
        },
        {
          "tier": 2,
          "pattern": "purlin:resume|checkpoint",
          "context": "Output references purlin:resume or checkpoint context"
        }
      ]
    },
    {
      "name": "restore-with-checkpoint-shows-summary",
      "prompt": "purlin:resume",
      "role": "PURLIN",
      "mode": "engineer",
      "fixture_tag": "main/pl_start/builder-mid-feature",
      "assertions": [
        {
          "tier": 1,
          "pattern": "Context Restored|Checkpoint|checkpoint|recovered|Recovered",
          "context": "Recovery summary banner or checkpoint reference is printed"
        },
        {
          "tier": 2,
          "pattern": "Engineer|engineer|Mode|Context|checkpoint|Checkpoint|session|Session",
          "context": "Recovery output references mode or checkpoint context"
        }
      ]
    },
    {
      "name": "restore-cold-start-no-checkpoint",
      "prompt": "purlin:resume",
      "role": "PURLIN",
      "fixture_tag": "main/pl_start/auto-mode",
      "setup_commands": [
        "rm -f .purlin/cache/session_checkpoint_*.md"
      ],
      "assertions": [
        {
          "tier": 2,
          "pattern": "no checkpoint|No checkpoint|cold start|fresh|none found|not found|None|no session|No session",
          "context": "Cold start indicates no checkpoint was found"
        }
      ]
    },
    {
      "name": "restore-prints-command-hint",
      "prompt": "purlin:resume",
      "role": "PURLIN",
      "mode": "engineer",
      "fixture_tag": "main/pl_start/builder-mid-feature",
      "assertions": [
        {
          "tier": 1,
          "pattern": "purlin:help|purlin:build|purlin:status",
          "context": "Command hint references available Purlin skills"
        }
      ]
    },
    {
      "name": "cold-start-find-work-false",
      "prompt": "purlin:resume",
      "role": "PURLIN",
      "fixture_tag": "main/pl_start/expert-mode",
      "assertions": [
        {
          "tier": 2,
          "pattern": "find_work.*false|find_work.*disabled|work discovery.*disabled|awaiting|waiting|Context Restored|Mode:|no checkpoint|cold start",
          "context": "Agent performs resume flow (find_work config not verifiable in --print mode)"
        }
      ]
    },
    {
      "name": "merge-recovery-reports-pending",
      "prompt": "purlin:resume merge-recovery",
      "role": "PURLIN",
      "fixture_tag": "main/pl_start/pending-merge",
      "assertions": [
        {
          "tier": 1,
          "pattern": "Pending merge|No pending merge|merge|breadcrumb",
          "context": "Merge recovery reports on pending merge state"
        }
      ]
    },
    {
      "name": "invalid-subcommand-shows-error",
      "prompt": "purlin:resume foobar",
      "role": "PURLIN",
      "fixture_tag": "main/pl_start/builder-mid-feature",
      "assertions": [
        {
          "tier": 2,
          "pattern": "Unknown argument|unknown|invalid|error|not recognized|foobar",
          "context": "Invalid argument produces an error message"
        },
        {
          "tier": 1,
          "pattern": "save|merge-recovery",
          "context": "Error lists valid subcommands"
        }
      ]
    },
    {
      "name": "resume-echoes-checkpoint-fields",
      "prompt": "purlin:resume",
      "role": "PURLIN",
      "mode": "engineer",
      "fixture_tag": "main/pl_start/builder-mid-feature",
      "assertions": [
        {
          "tier": 2,
          "pattern": "feature|Feature|my_feature|features/",
          "context": "Checkpoint feature context appears in recovery output"
        }
      ]
    },
    {
      "name": "qa-resume-echoes-checkpoint-fields",
      "prompt": "purlin:resume",
      "role": "PURLIN",
      "mode": "qa",
      "fixture_tag": "main/pl_start/qa-mid-verification",
      "assertions": [
        {
          "tier": 2,
          "pattern": "QA|qa|verification|verify",
          "context": "QA mode or verification context appears in recovery output"
        }
      ]
    }
  ]
}
