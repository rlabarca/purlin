{
  "feature": "cdd_startup_controls",
  "harness_type": "web_test",
  "scenarios": [
    {
      "name": "startup_controls_render",
      "setup_commands": ["tools/cdd/start.sh -p 9086 > /dev/null 2>&1; sleep 2"],
      "web_test_url": "http://localhost:9086",
      "assertions": [
        {
          "tier": 2,
          "pattern": "(?i)(find.work|auto.start|startup|start.up)",
          "context": "dashboard renders startup control labels (find_work, auto_start)"
        },
        {
          "tier": 1,
          "pattern": "(?i)(checkbox|checked|disabled|enabled)",
          "context": "dashboard contains checkbox controls for startup flags"
        }
      ]
    }
  ]
}
