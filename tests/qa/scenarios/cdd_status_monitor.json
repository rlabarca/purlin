{
  "feature": "cdd_status_monitor",
  "harness_type": "web_test",
  "scenarios": [
    {
      "name": "status_monitor_dashboard_structure",
      "setup_commands": ["tools/cdd/start.sh -p 9086 > /dev/null 2>&1; sleep 2"],
      "web_test_url": "http://localhost:9086",
      "assertions": [
        {
          "tier": 2,
          "pattern": "(?i)(architect|builder|qa|pm|done|todo|complete|testing)",
          "context": "dashboard displays role status columns (Architect, Builder, QA, PM) or lifecycle states"
        },
        {
          "tier": 1,
          "pattern": "(?i)(feature|active|complete|section)",
          "context": "dashboard contains feature sections"
        }
      ]
    },
    {
      "name": "status_monitor_empty_active",
      "web_test_url": "http://localhost:9086",
      "assertions": [
        {
          "tier": 1,
          "pattern": "(?i)(active|complete|feature|purlin)",
          "context": "dashboard renders even when active section is empty"
        }
      ]
    }
  ]
}
