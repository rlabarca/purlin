{
  "feature": "purlin_worktree",
  "description": "Regression tests for purlin:worktree skill: manage.sh list/check-lock/claim/cleanup-stale subcommands, session-end-merge hook integration, and concurrent access protection.",
  "harness_type": "custom_script",
  "scenarios": [
    {
      "name": "manage-list-subcommand",
      "script_path": "tests/purlin_worktree/test_worktree_management.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "returns empty array",
          "context": "List returns empty worktrees array when none exist"
        },
        {
          "tier": 2,
          "pattern": "has W1 label",
          "context": "List shows worktree label from .purlin_worktree_label"
        },
        {
          "tier": 2,
          "pattern": "status is active",
          "context": "Live PID worktree classified as active"
        },
        {
          "tier": 2,
          "pattern": "mode is engineer",
          "context": "Mode read from session lock file"
        },
        {
          "tier": 2,
          "pattern": "has stale entry",
          "context": "Dead PID worktree classified as stale"
        },
        {
          "tier": 2,
          "pattern": "has orphaned entry",
          "context": "No-lock worktree classified as orphaned"
        }
      ]
    },
    {
      "name": "manage-check-lock-subcommand",
      "script_path": "tests/purlin_worktree/test_worktree_management.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "safe is true.*status is orphaned",
          "context": "Orphaned worktree is safe to claim"
        },
        {
          "tier": 2,
          "pattern": "safe is true.*status is stale",
          "context": "Stale worktree is safe to claim"
        },
        {
          "tier": 2,
          "pattern": "safe is false.*status is active",
          "context": "Active worktree is NOT safe to claim"
        }
      ]
    },
    {
      "name": "manage-claim-subcommand",
      "script_path": "tests/purlin_worktree/test_worktree_management.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "claimed is true",
          "context": "Stale/orphaned worktree can be claimed"
        },
        {
          "tier": 2,
          "pattern": "label preserved",
          "context": "Claim preserves existing worktree label"
        },
        {
          "tier": 2,
          "pattern": "mode updated to qa",
          "context": "Claim updates mode in session lock"
        },
        {
          "tier": 2,
          "pattern": "rejected with error",
          "context": "Active worktree claim is rejected"
        }
      ]
    },
    {
      "name": "manage-cleanup-stale-subcommand",
      "script_path": "tests/purlin_worktree/test_worktree_management.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "cleaned W2",
          "context": "Stale worktree with no changes is removed"
        },
        {
          "tier": 2,
          "pattern": "skipped W1",
          "context": "Active worktree is skipped during cleanup"
        },
        {
          "tier": 2,
          "pattern": "reports uncommitted",
          "context": "Dirty stale worktree reported with uncommitted flag"
        },
        {
          "tier": 2,
          "pattern": "dry-run did not remove worktree",
          "context": "Dry-run mode does not actually remove worktrees"
        }
      ]
    },
    {
      "name": "session-end-merge-integration",
      "script_path": "tests/purlin_worktree/test_worktree_management.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "branch deleted after merge",
          "context": "Session-end hook auto-commits and merges tracked changes"
        },
        {
          "tier": 2,
          "pattern": "change merged to source",
          "context": "Merged content lands on source branch"
        },
        {
          "tier": 2,
          "pattern": "untracked file merged to source",
          "context": "Hook auto-commits and merges untracked files"
        },
        {
          "tier": 2,
          "pattern": "breadcrumb written",
          "context": "Merge conflict produces breadcrumb JSON"
        },
        {
          "tier": 2,
          "pattern": "branch preserved after conflict",
          "context": "Branch survives merge conflict for later resume"
        },
        {
          "tier": 2,
          "pattern": "stale breadcrumb deleted",
          "context": "Successful merge cleans up prior failed-merge breadcrumbs"
        },
        {
          "tier": 2,
          "pattern": "non-purlin branch not touched",
          "context": "Hook only processes purlin-prefixed branches"
        },
        {
          "tier": 2,
          "pattern": "exits 0 with no worktrees",
          "context": "Hook exits cleanly when no worktrees exist"
        },
        {
          "tier": 2,
          "pattern": "work merged despite stale lock",
          "context": "Hook handles stale merge lock from dead process"
        },
        {
          "tier": 2,
          "pattern": "exits 0 even on conflict",
          "context": "Hook always exits 0, even on merge conflicts"
        }
      ]
    }
  ]
}
