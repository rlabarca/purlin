{
  "feature": "cdd_qa_effort_display",
  "harness_type": "web_test",
  "scenarios": [
    {
      "name": "qa_effort_badges_render",
      "setup_commands": [
        "tools/cdd/start.sh -p 9086 > /dev/null 2>&1; sleep 2"
      ],
      "web_test_url": "http://localhost:9086",
      "assertions": [
        {
          "tier": 2,
          "pattern": "st-auto",
          "context": "AUTO badge CSS class present in QA column cells for auto-only features"
        },
        {
          "tier": 2,
          "pattern": "purlin-status-auto",
          "context": "AUTO status color token defined in dashboard CSS"
        },
        {
          "tier": 1,
          "pattern": "(?i)(AUTO|TODO)",
          "context": "dashboard renders QA status badges (AUTO and/or TODO) in feature table"
        }
      ]
    }
  ]
}
