{
  "feature": "purlin_status",
  "description": "Regression scenarios for purlin:status: feature lifecycle counts and mode guidance in different project states.",
  "harness_type": "agent_behavior",
  "scenarios": [
    {
      "name": "status-shows-feature-counts",
      "prompt": "purlin:status",
      "role": "PURLIN",
      "fixture_tag": "main/cdd_lifecycle/mixed-statuses",
      "assertions": [
        {
          "tier": 1,
          "pattern": "TODO|TESTING|COMPLETE|todo|testing|complete",
          "context": "Output contains lifecycle status categories"
        },
        {
          "tier": 2,
          "pattern": "purlin:mode|purlin:build|purlin:verify|Engineer|PM|QA|mode",
          "context": "Output references available modes or next steps"
        }
      ]
    },
    {
      "name": "status-all-complete",
      "prompt": "purlin:status",
      "role": "PURLIN",
      "fixture_tag": "main/cdd_lifecycle/all-complete",
      "assertions": [
        {
          "tier": 1,
          "pattern": "COMPLETE|complete|All.*complete|all.*done|finished",
          "context": "Output reflects all-complete project state"
        },
        {
          "tier": 2,
          "pattern": "purlin:|feature|Feature|status|project",
          "context": "Output provides meaningful project summary"
        }
      ]
    }
  ]
}
