{
  "feature": "collab_whats_different",
  "harness_type": "web_test",
  "scenarios": [
    {
      "name": "whats_different_diverged",
      "setup_commands": ["tools/cdd/start.sh -p 9086 > /dev/null 2>&1; sleep 2"],
      "web_test_url": "http://localhost:9086",
      "assertions": [
        {
          "tier": 2,
          "pattern": "(?i)(different|diverge|ahead|behind|branch|collab|sync)",
          "context": "dashboard shows branch sync state or what's different content"
        },
        {
          "tier": 1,
          "pattern": "(?i)(feature|change|commit|status)",
          "context": "dashboard renders feature or change information"
        }
      ]
    }
  ]
}
