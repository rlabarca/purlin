{
  "feature": "cdd_agent_configuration",
  "harness_type": "web_test",
  "scenarios": [
    {
      "name": "agent_config_dashboard_renders",
      "setup_commands": ["tools/cdd/start.sh -p 9086 > /dev/null 2>&1; sleep 2"],
      "web_test_url": "http://localhost:9086",
      "assertions": [
        {
          "tier": 2,
          "pattern": "(?i)(agent|config|model|architect|builder|qa|pm)",
          "context": "dashboard renders agent configuration section with role/model references"
        },
        {
          "tier": 1,
          "pattern": "(?i)(checkbox|select|input|button|form|control)",
          "context": "dashboard contains UI controls for agent configuration"
        }
      ]
    }
  ]
}
