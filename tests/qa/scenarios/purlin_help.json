{
  "feature": "purlin_help",
  "description": "Regression scenarios for purlin:help: command table structure and skill file presence.",
  "harness_type": "custom_script",
  "scenarios": [
    {
      "name": "command-table-structure",
      "script_path": "tests/purlin_help/test_command_table.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "command table contains all mode sections",
          "context": "purlin_commands.md has Common, Engineer, PM, and QA sections"
        },
        {
          "tier": 2,
          "pattern": "command table lists core commands",
          "context": "purlin_commands.md lists purlin:status, purlin:mode, purlin:help"
        }
      ]
    },
    {
      "name": "help-skill-exists",
      "script_path": "tests/purlin_help/test_help_skill.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "help skill file exists",
          "context": "skills/help/SKILL.md is present"
        },
        {
          "tier": 2,
          "pattern": "help skill references purlin_commands.md",
          "context": "Help skill reads command table from purlin_commands.md"
        }
      ]
    }
  ]
}
