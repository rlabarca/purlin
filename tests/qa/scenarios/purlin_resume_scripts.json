{
  "feature": "purlin_resume",
  "description": "Regression scenarios for Purlin unified agent session entry point: instruction stack assembly and help flag presence.",
  "harness_type": "custom_script",
  "scenarios": [
    {
      "name": "instruction-stack-assembly",
      "script_path": "tests/purlin_resume/purlin_resume_scripts/test_instruction_stack.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "PURLIN_BASE\\.md found in instructions",
          "context": "PURLIN_BASE.md exists in instructions directory"
        },
        {
          "tier": 2,
          "pattern": "construct_system_prompt handles PURLIN role",
          "context": "Harness runner constructs PURLIN system prompt for the PURLIN role"
        }
      ]
    },
    {
      "name": "help-output-flags",
      "script_path": "tests/purlin_resume/purlin_resume_scripts/test_help_flags.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "resume skill contains --yolo",
          "context": "The resume skill references --yolo flag"
        },
        {
          "tier": 2,
          "pattern": "resume skill contains --no-yolo",
          "context": "The resume skill references --no-yolo flag"
        },
        {
          "tier": 2,
          "pattern": "resume skill contains --no-save",
          "context": "The resume skill references --no-save flag"
        }
      ]
    },
    {
      "name": "config-persistence-types",
      "script_path": "tests/purlin_resume/purlin_resume_scripts/test_config_types.sh",
      "assertions": [
        {
          "tier": 2,
          "pattern": "boolean fields persist as JSON booleans",
          "context": "Config engine coerces string 'true'/'false' to JSON booleans for boolean fields"
        },
        {
          "tier": 2,
          "pattern": "missing agents.purlin returns safe defaults",
          "context": "Role resolution falls back to builder config when agents.purlin is absent"
        },
        {
          "tier": 2,
          "pattern": "startup control values resolve correctly",
          "context": "find_work and auto_start config values appear in role resolution output"
        }
      ]
    }
  ]
}
