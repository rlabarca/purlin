# OS & Editors
.DS_Store
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
env/
venv/

# Purlin Runtime & Cache
.purlin/cache/
.purlin/runtime/
.purlin/config.local.json
tests/.purlin/

# Project-local toolbox
.purlin/toolbox/project_tools.json
.purlin/toolbox/community_tools.json
.purlin/toolbox/community/

# Plugin data (persists across updates)
.claude-plugin-data/

# MCP server config (machine-specific)
.mcp.json

# Dev scratch space
dev/

# Generated digests (per-machine, not committed)
features/_digests/
features/digests/

# Purlin Tool Logs & Artifacts
*.log
*.pid
*.mmd
# Web-verify screenshots
*.png
!assets/*.png
!docs/images/*.png
*.jpeg

# Worktrees (both Purlin agent and Claude Code sub-agent)
.purlin/worktrees/
.claude/worktrees/
.purlin_worktree_label
.purlin_session.lock

# Transient planning artifacts
PURLIN_AGENT_PLAN.md

# Credential files (must never be committed)
credentials.json
*.credentials
*.secret

# Temp
tmp/
dist/
build/
.playwright-mcp/
