# OS & Editors
.DS_Store
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
env/
venv/

# Purlin Runtime & Cache
.purlin/runtime/
.purlin/config.local.json
.purlin/plugins/__pycache__/
.purlin/cache/

# Plugin data (persists across updates)
.claude-plugin-data/

# MCP server config (machine-specific)
.mcp.json

# Purlin Tool Logs & Artifacts
*.log
*.pid
*.mmd
*.png
!docs/images/*.png
*.jpeg

# Worktrees (both Purlin agent and Claude Code sub-agent)
.purlin/worktrees/
.claude/worktrees/
.purlin_worktree_label
.purlin_session.lock

# Dashboard report (generated by sync_status + purlin:init)
/purlin-report.html
.purlin/report-data.js

# Transient planning artifacts
PURLIN_AGENT_PLAN.md

# Credential files (must never be committed)
credentials.json
*.credentials
*.secret

# Temp
tmp/
dist/
build/
.playwright-mcp/
